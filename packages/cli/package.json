{
  "name": "@deepicode/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "deepicode": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@deepicode/core": "workspace:*",
    "@deepicode/tools": "workspace:*",
    "@deepicode/mcp": "workspace:*",
    "@deepicode/tui": "workspace:*",
    "@deepicode/plugin": "workspace:*"
  }
}
